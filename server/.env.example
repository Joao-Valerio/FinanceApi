# Porta em que a API vai rodar
PORT=3333

# URL(s) do front usadas no CORS (separe por vírgula para múltiplas origens)
# Exemplo em produção: FRONTEND_URL=https://meu-app.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# String de conexão do banco (Neon ou Postgres local)
# Exemplo com Neon (recomendado):
# DATABASE_URL="postgresql://<usuario>:<senha>@<endpoint>-pooler.sa-east-1.aws.neon.tech/<banco>?sslmode=require&channel_binding=require"
# Exemplo com Docker local:
# DATABASE_URL="postgresql://financeapi:financeapi@localhost:5433/financeapi?schema=public"
DATABASE_URL="postgresql://<usuario>:<senha>@<host>/<banco>?sslmode=require"

# Segredo do JWT (troque em produção!)
JWT_SECRET="troque-este-segredo-em-producao"
JWT_EXPIRES_IN="7d"
